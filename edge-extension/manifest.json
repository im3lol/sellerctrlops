{
  "manifest_version": 3,
  "name": "SellerCtrl — السحب الذكي",
  "version": "1.0.0",
  "description": "التقاط بيانات المنتجات من موقع العميل بتحديد العناصر تفاعلياً، ثم تشغيل السحب على كل المنتجات المسودة وحفظ البيانات في SellerCtrl.",
  "permissions": ["storage", "scripting", "tabs", "sidePanel"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "SellerCtrl — السحب الذكي",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
