# Copy to .env and fill in. The worker only makes OUTBOUND requests to APP_URL.

# Base URL of the SellerCtrl app (the Vercel deployment, or http://host.docker.internal:3000 for a local app)
APP_URL=https://sellerctrlops.vercel.app

# MUST match the app's SCRAPER_TOKEN env var exactly.
SCRAPER_TOKEN=

# Optional tuning
POLL_INTERVAL_MS=5000
ITEM_DELAY_MS=1500
NAV_TIMEOUT_MS=30000
# HEADLESS=true
# BROWSER_CHANNEL=msedge   # only if Edge is installed in the image
