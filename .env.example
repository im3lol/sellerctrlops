# ─── Database (Postgres) ───────────────────────────────────────
# Local Docker:
DATABASE_URL=postgres://sellerctrl:sellerctrl@localhost:5432/sellerctrl
#
# Supabase (it's just Postgres — the app uses Drizzle/pg, NOT the JS SDK,
# so the anon/service_role keys are not needed here). Copy the URI from:
#   Supabase Dashboard → Project Settings → Database → Connection string → URI
# It looks like one of:
#   postgresql://postgres:[PASSWORD]@db.zacfpsjsimpuzkjtanfo.supabase.co:5432/postgres
#   postgresql://postgres.zacfpsjsimpuzkjtanfo:[PASSWORD]@aws-0-<region>.pooler.supabase.com:6543/postgres
# Then: npm run db:migrate && npm run db:seed

# ─── Auth (Auth.js v5) ─────────────────────────────────────────
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=replace-me-with-a-long-random-string
AUTH_TRUST_HOST=true

# ─── Object storage (MinIO / S3-compatible) ────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=sellerctrl
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
# Public base URL used to build file links (proxy through the app)
S3_PUBLIC_URL=http://localhost:9000/sellerctrl

# ─── Google Sheets integration ─────────────────────────────────
# Paste the full service-account JSON on one line, OR mount a file and set the path.
GOOGLE_SERVICE_ACCOUNT_JSON=
# GOOGLE_SERVICE_ACCOUNT_FILE=/run/secrets/google-sa.json

# ─── AI Operations Assistant (Anthropic Claude) ───────────────
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6

# ─── App ───────────────────────────────────────────────────────
APP_URL=http://localhost:3000
NODE_ENV=development
